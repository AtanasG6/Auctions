@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="flex min-h-full flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="mx-auto size-12 text-indigo-600">
            <path d="M5.566 4.657A4.505 4.505 0 0 1 6.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0 0 15.75 3h-7.5a3 3 0 0 0-2.684 1.657ZM2.25 12a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-6ZM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 0 1 6.75 6h10.5a3 3 0 0 1 2.683 1.657A4.505 4.505 0 0 0 18.75 7.5H5.25Z" />
        </svg>
        
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-gray-900">Sign out</h2>
            <p class="mt-2 text-center text-sm text-gray-600">Are you sure you want to log out?</p>
            
            <div class="mt-8">
                <div class="bg-white px-6 py-8 shadow sm:rounded-lg sm:px-10">
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <button type="submit" class="flex w-full justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                            Sign out
                        </button>
                    </form>
                    <div class="mt-4">
                        <a asp-page="/Index" asp-area="" class="flex w-full justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                            Cancel
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-gray-900">Signed out</h2>
            <div class="mt-8">
                <div class="bg-white px-6 py-8 shadow sm:rounded-lg sm:px-10 text-center">
                    <div class="rounded-md bg-green-50 p-4 mb-6">
                        <div class="flex justify-center">
                            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <p class="mt-2 text-sm text-green-700">You have successfully logged out.</p>
                    </div>
                    <a asp-page="/Index" asp-area="" class="inline-flex justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                        Return to Home
                    </a>
                </div>
            </div>
        }
    </div>
</div>