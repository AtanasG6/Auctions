﻿
<!DOCTYPE html>

<html class="h-full bg-gray-100">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title - Auctions</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />

</head>
<body class="h-full">
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindplus/elements@1" type="module"></script>

    <div class="min-h-full flex flex-col">
        <nav class="bg-indigo-700">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="flex h-16 items-center justify-between">
                    <div class="flex items-center">
                        <div class="shrink-0">
                            <a asp-controller="Listings" asp-action="Index" class="flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8 text-white">
                                    <path d="M5.566 4.657A4.505 4.505 0 0 1 6.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0 0 15.75 3h-7.5a3 3 0 0 0-2.684 1.657ZM2.25 12a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-6ZM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 0 1 6.75 6h10.5a3 3 0 0 1 2.683 1.657A4.505 4.505 0 0 0 18.75 7.5H5.25Z" />
                                </svg>
                                <span class="text-xl font-bold text-white">Auctions</span>
                            </a>
                        </div>
                        <div class="hidden md:block">
                            <div class="ml-10 flex items-baseline space-x-4">
                                <a asp-controller="Listings" asp-action="Index" class="rounded-md px-3 py-2 text-sm font-medium text-white hover:bg-indigo-600">Active Listings</a>
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <a asp-controller="Listings" asp-action="MyListings" class="rounded-md px-3 py-2 text-sm font-medium text-white hover:bg-indigo-600">My Listings</a>
                                    <a asp-controller="Listings" asp-action="MyBids" class="rounded-md px-3 py-2 text-sm font-medium text-white hover:bg-indigo-600">My Bids</a>
                                    <a asp-controller="Listings" asp-action="Create" class="rounded-md px-3 py-2 text-sm font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">Create Listing</a>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block">
                        <div class="ml-4 flex items-center gap-3 md:ml-6">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <!-- Profile dropdown for authenticated users -->
                                <el-dropdown class="relative">
                                    <button class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-white hover:bg-indigo-600">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                            <path fill-rule="evenodd" d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.285A7.486 7.486 0 0 1 12 15a7.486 7.486 0 0 1 5.855 2.812A8.224 8.224 0 0 1 12 20.25a8.224 8.224 0 0 1-5.855-2.438ZM15.75 9a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" clip-rule="evenodd" />
                                        </svg>
                                        <span>@User.Identity.Name</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4">
                                            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                                        </svg>
                                    </button>

                                    <el-menu anchor="bottom end" popover class="w-48 origin-top-right rounded-md bg-white py-1 shadow-lg outline-1 outline-black/5 transition transition-discrete [--anchor-gap:--spacing(2)] data-closed:scale-95 data-closed:transform data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
                                        <a asp-area="Identity" asp-page="/Account/Manage/Index" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Your Profile</a>
                                        <a asp-controller="Listings" asp-action="MyListings" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">My Listings</a>
                                        <hr class="my-1 border-gray-200" />
                                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Listings", new { area = "" })" method="post">
                                            <button type="submit" class="block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100">Sign out</button>
                                        </form>
                                    </el-menu>
                                </el-dropdown>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" class="rounded-md px-4 py-2 text-sm font-medium text-white hover:bg-indigo-600">
                                    Login
                                </a>
                                <a asp-area="Identity" asp-page="/Account/Register" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm hover:bg-indigo-50">
                                    Register
                                </a>
                            }
                        </div>
                    </div>
                    <div class="-mr-2 flex md:hidden">
                        <!-- Mobile menu button -->
                        <button type="button" command="--toggle" commandfor="mobile-menu" class="relative inline-flex items-center justify-center rounded-md p-2 text-indigo-200 hover:bg-indigo-600 hover:text-white focus:outline-2 focus:outline-offset-2 focus:outline-white">
                            <span class="absolute -inset-0.5"></span>
                            <span class="sr-only">Open main menu</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6 in-aria-expanded:hidden">
                                <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6 not-in-aria-expanded:hidden">
                                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <el-disclosure id="mobile-menu" hidden class="block md:hidden">
                <div class="space-y-1 px-2 pt-2 pb-3 sm:px-3">
                    <a asp-controller="Listings" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-white hover:bg-indigo-600">Home</a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-controller="Listings" asp-action="MyListings" class="block rounded-md px-3 py-2 text-base font-medium text-white hover:bg-indigo-600">My Listings</a>
                        <a asp-controller="Listings" asp-action="MyBids" class="block rounded-md px-3 py-2 text-base font-medium text-white hover:bg-indigo-600">My Bids</a>
                        <a asp-controller="Listings" asp-action="Create" class="block rounded-md px-3 py-2 text-base font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">Create Listing</a>

                    }
                </div>
                <div class="border-t border-indigo-600 pt-4 pb-3">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="flex items-center px-5">
                            <div class="shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-10 text-indigo-200">
                                    <path fill-rule="evenodd" d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.285A7.486 7.486 0 0 1 12 15a7.486 7.486 0 0 1 5.855 2.812A8.224 8.224 0 0 1 12 20.25a8.224 8.224 0 0 1-5.855-2.438ZM15.75 9a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="ml-3">
                                <div class="text-base font-medium text-white">@User.Identity.Name</div>
                            </div>
                        </div>
                        <div class="mt-3 space-y-1 px-2">
                            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="block rounded-md px-3 py-2 text-base font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">Your Profile</a>
                            <a asp-controller="Listings" asp-action="MyListings" class="block rounded-md px-3 py-2 text-base font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">My Listings</a>
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Listings", new { area = "" })" method="post">
                                <button type="submit" class="block w-full rounded-md px-3 py-2 text-left text-base font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">Sign out</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-1 px-2">
                            <a asp-area="Identity" asp-page="/Account/Login" class="block rounded-md px-3 py-2 text-base font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">Login</a>
                            <a asp-area="Identity" asp-page="/Account/Register" class="block rounded-md px-3 py-2 text-base font-medium text-indigo-200 hover:bg-indigo-600 hover:text-white">Register</a>
                        </div>
                    }
                </div>
            </el-disclosure>
        </nav>

        <header class="relative bg-white shadow-sm">
            <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                <h1 class="text-3xl font-bold tracking-tight text-gray-900">@ViewData["Title"]</h1>
            </div>
        </header>
        <main>
            <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                @RenderBody()
            </div>
        </main>

        <footer class="bg-gray-800 mt-auto">
            <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                <p class="text-center text-sm text-gray-400">&copy; @DateTime.Now.Year Auctions. All rights reserved.</p>
            </div>
        </footer>
    </div>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>