@model IEnumerable<Listing>
@{
    ViewData["Title"] = "Auction Listings";

}

<div class="max-w-7xl mx-auto py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        @foreach (var listing in Model)
        {
            <div class="bg-gray-500/60 p-4 rounded-lg flex flex-col">
                <div class="mb-4">
                    <img src="~/Images/@listing.ImagePath"
                         class="w-full h-48 object-contain"
                         alt="@listing.Title" />
                </div>
                <div class="space-y-2 flex-1">
                    <h5 class="text-lg font-semibold">
                        <a asp-action="Details"
                           asp-route-id="@listing.ListingId"
                           class="text-black hover:text-gray-700 hover:underline">
                            @listing.Title
                        </a>
                    </h5>
                    <p class="text-gray-800 text-sm line-clamp-2">@listing.Description</p>
                    <p class="font-medium">Bid: $@listing.Price.ToString("N2")</p>
                    <p class="text-sm text-gray-700">Listed by: @listing.User.Email</p>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <p>No Active Listings</p>
        }
    </div>
</div>
