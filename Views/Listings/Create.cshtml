@model ListingVM

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> userManager
@{
    ViewData["Title"] = "Create New Listing";
}

<div class="max-w-md mx-auto mt-8">
    <form asp-action="Create" enctype="multipart/form-data" class="space-y-6">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
        <div>
            <label asp-for="Title" class="block text-sm font-medium text-gray-700"></label>
            <input asp-for="Title" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" />
            <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
        </div>
        <div>
            <label asp-for="Description" class="block text-sm font-medium text-gray-700"></label>
            <textarea asp-for="Description" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
        </div>
        <div>
            <label asp-for="Price" class="block text-sm font-medium text-gray-700">Starting Bid</label>
            <input asp-for="Price" type="number" step="0.01" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none" />
            <span asp-validation-for="Price" class="text-red-500 text-sm"></span>
        </div>
        <div>
            <label asp-for="Image" class="block text-sm font-medium text-gray-700"></label>
            <input asp-for="Image" class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" accept="image/*" />
            <span asp-validation-for="Image" class="text-red-500 text-sm"></span>
        </div>
        <input type="hidden" asp-for="UserId" value="@userManager.GetUserId(User)" />
        <div>
            <input type="submit" value="Create" class="inline-flex justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" />
        </div>
    </form>
    <div class="mt-6">
        <a asp-action="Index" class="text-indigo-600 hover:text-indigo-500 hover:underline">← Back to List</a>
    </div>
</div>